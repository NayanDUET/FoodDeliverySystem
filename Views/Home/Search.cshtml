@model FoodDeliverySystem.ViewModels.SearchResultVM

<div class="container my-4">

    <!-- Page Header & Search Context -->
    <div class="mb-4">
        <span class="text-uppercase tracking-wider text-muted fs-7 fw-bold">Marketplace Search</span>
        <h2 class="fw-bold text-dark mb-1">
            Search Results for: <span class="text-primary">"@Model.Keyword"</span>
        </h2>
        <p class="text-muted small">We found the following matches across our partner kitchens and menus</p>
    </div>

    <!-- RESTAURANTS SECTION -->
    <div class="mb-5">
        <div class="d-flex align-items-center gap-2 mb-3">
            <h3 class="fw-bold text-dark fs-4 mb-0">Partner Restaurants</h3>
            <span class="badge rounded-pill bg-light text-dark border fw-medium px-2.5 py-1">@Model.Restaurants.Count()</span>
        </div>

        <div class="row g-3">
            @if (!Model.Restaurants.Any())
            {
                <div class="col-12">
                    <div class="p-4 border border-dashed rounded-3 bg-white text-center text-muted">
                        <span class="fs-3 d-block mb-1">🏪</span>
                        <p class="mb-0 fw-medium small">No restaurants matched your search keyword.</p>
                    </div>
                </div>
            }
            else
            {
                @foreach (var item in Model.Restaurants)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 border-0 shadow-sm hover-lift bg-white" style="border-radius: 0.75rem;">
                            <div class="card-body p-3.5 d-flex align-items-start gap-3">
                                <div class="bg-primary-subtle text-primary rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 45px; height: 45px; min-width: 45px;">
                                    <i class="bi bi-shop fs-5"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <h5 class="fw-bold text-dark text-truncate mb-1" title="@item.Name">
                                        @item.Name
                                    </h5>
                                    <p class="text-muted small mb-0 text-truncate" title="@item.Address">
                                        <i class="bi bi-geo-alt me-1 text-danger-subtle"></i> @item.Address
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- FOOD ITEMS SECTION -->
    <div>
        <div class="d-flex align-items-center gap-2 mb-3">
            <h3 class="fw-bold text-dark fs-4 mb-0">Menu Items & Dishes</h3>
            <span class="badge rounded-pill bg-light text-dark border fw-medium px-2.5 py-1">@Model.Foods.Count()</span>
        </div>

        <div class="row g-4">
            @if (!Model.Foods.Any())
            {
                <div class="col-12">
                    <div class="p-5 border border-dashed rounded-3 bg-white text-center text-muted">
                        <span class="fs-2 d-block mb-2">🍽️</span>
                        <p class="mb-0 fw-medium">No dishes match your search.</p>
                        <small class="text-secondary">Try searching for ingredients, cuisines, or item titles.</small>
                    </div>
                </div>
            }
            else
            {
                @foreach (var food in Model.Foods)
                {
                    <div class="col-sm-6 col-md-4 col-lg-3">
                        <div class="card h-100 border-0 shadow-sm hover-lift bg-white overflow-hidden" style="border-radius: 1rem;">

                            <!-- Image Display Window with Fallback Flag -->
                            <div class="position-relative bg-light" style="height: 180px;">
                                @if (!string.IsNullOrEmpty(food.ImageUrl))
                                {
                                    <img src="@food.ImageUrl" class="w-100 h-100 object-fit-cover" alt="@food.Name" />
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted opacity-50">
                                        <span class="fs-1">🍲</span>
                                        <span class="x-small fw-medium mt-1">No Image Available</span>
                                    </div>
                                }
                                <!-- Floating Absolute Pricing Tag -->
                                <div class="position-absolute bottom-0 start-0 m-3 bg-dark text-white fw-bold px-3 py-1 rounded-pill shadow-sm fs-7 backdrop-blur">
                                    @food.Price <span class="fw-normal fs-8">TK</span>
                                </div>
                            </div>

                            <!-- Card Context Details -->
                            <div class="card-body p-3.5 d-flex flex-column justify-content-between">
                                <div class="mb-3">
                                    <h5 class="fw-bold text-dark mb-1 text-truncate" title="@food.Name">
                                        @food.Name
                                    </h5>
                                    <p class="text-muted fs-7 mb-0 text-truncate" title="@food.Restaurant?.Name">
                                        <i class="bi bi-egg-fried me-1 text-warning"></i> @(food.Restaurant?.Name ?? "Partner Kitchen")
                                    </p>
                                </div>

                                <!-- Action Trigger Row -->
                                <a asp-controller="Order" asp-action="Create" asp-route-foodItemId="@food.Id"
                                   class="btn btn-success w-100 rounded-pill fw-bold shadow-sm py-2 d-flex align-items-center justify-content-center gap-2 btn-order">
                                    <i class="bi bi-cart-plus-fill"></i> Order Now
                                </a>
                            </div>

                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    /* Premium UI Additions and Layout Parity Hooks */
    .fs-7 {
        font-size: 0.85rem;
    }

    .fs-8 {
        font-size: 0.75rem;
    }

    .x-small {
        font-size: 0.7rem;
    }

    .p-3.5 {
        padding: 0.875rem !important;
    }

    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
    }

    .backdrop-blur {
        data-backdrop: blur;
        background-color: rgba(33, 37, 41, 0.85) !important;
        backdrop-filter: blur(4px);
    }

    /* Interactive Card Hover Transforms */
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hover-lift:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.08) !important;
        }

    /* Order button active visual states */
    .btn-order {
        transition: background-color 0.15s ease, transform 0.1s ease;
    }

        .btn-order:active {
            transform: scale(0.98);
        }
</style>