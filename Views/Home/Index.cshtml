@{
    ViewData["Title"] = "Home Page";
}

@model IEnumerable<FoodDeliverySystem.Models.Entities.FoodItem>

<div class="container my-5">

    <!-- Marketplace Subheader greeting -->
    <div class="mb-4">
        <h2 class="fw-bold text-dark mb-1">Discover Delicious Food</h2>
        <p class="text-muted small">Fresh meals from your favorite local restaurants delivered fast</p>
    </div>

    <!-- Cards Grid -->
    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <span class="fs-1">🍽️</span>
                <h4 class="fw-bold text-muted mt-3">No dishes available right now</h4>
                <p class="text-secondary small">Check back later or explore other options!</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm food-card position-relative bg-white" style="border-radius: 1rem; overflow: hidden;">

                        <!-- Floating Price Tag Badge -->
                        <span class="badge bg-dark fs-6 py-2 px-3 position-absolute top-0 end-0 m-3 shadow fw-bold rounded-pill text-white">
                            @item.Price TK
                        </span>

                        <!-- Food Item Image Frame -->
                        <div class="overflow-hidden" style="height: 200px;">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="card-img-top w-100 h-100 object-fit-cover food-img" alt="@item.Name" />
                            }
                            else
                            {
                                <div class="bg-light w-100 h-100 d-flex align-items-center justify-content-center text-muted fs-1">
                                    🍔
                                </div>
                            }
                        </div>

                        <!-- Card Metadata Content -->
                        <div class="card-body d-flex flex-column p-4">

                            <!-- Food Name -->
                            <h5 class="card-title fw-bold text-dark text-truncate mb-2" title="@item.Name">
                                @item.Name
                            </h5>

                            <!-- Restaurant Meta Properties -->
                            <div class="mb-3 flex-grow-1">
                                <div class="d-flex align-items-center mb-1 text-secondary small">
                                    <span class="me-1">🏬</span>
                                    <span class="fw-semibold text-dark text-truncate">@(item.Restaurant?.Name ?? "Local Kitchen")</span>
                                </div>
                                <div class="d-flex align-items-start text-muted x-small">
                                    <span class="me-1">📍</span>
                                    <span class="text-wrap">@(item.Restaurant?.Address ?? "Delivery Available")</span>
                                </div>
                            </div>

                            <!-- Integrated Action Button -->
                            <a asp-controller="Order" asp-action="Create" asp-route-foodItemId="@item.Id"
                               class="btn btn-success w-100 py-2 fw-bold shadow-sm rounded-pill btn-order transition-all">
                                Order Now
                            </a>
                        </div>

                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    /* Premium Visual Transitions */
    .food-card {
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s ease;
    }

        .food-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,0.12) !important;
        }

    .food-img {
        transition: transform 0.4s ease;
    }

    .food-card:hover .food-img {
        transform: scale(1.06);
    }

    .btn-order:hover {
        background-color: #146c43 !important;
        transform: scale(1.02);
    }

    .x-small {
        font-size: 0.8rem;
    }

    .text-wrap {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>