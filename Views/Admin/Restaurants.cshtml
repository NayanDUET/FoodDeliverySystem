@{
}
@model IEnumerable<FoodDeliverySystem.Models.Entities.Restaurant>

<h2>Restaurants</h2>

<table class="table table-bordered">

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Address</td>

            <td>
                <a asp-action="RestaurantFoods"
                   asp-route-id="@item.Id"
                   class="btn btn-info">
                    Foods
                </a>
            </td>
        </tr>
    }

</table>