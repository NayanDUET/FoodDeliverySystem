@model IEnumerable<FoodDeliverySystem.Models.Entities.Order>

<div class="container my-4">

   
    <div class="mb-4">
        <span class="text-uppercase tracking-wider text-muted fs-7 fw-bold">Transaction Ledgers</span>
        <h2 class="fw-bold text-dark mb-1">Global Orders Ledger</h2>
        <p class="text-muted small">Monitor real-time system performance, ticket totals, and operational logistics status lines</p>
    </div>

   
    <div class="card shadow-lg border-0" style="border-radius: 1rem; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="table-light text-uppercase fs-7 text-muted">
                    <tr>
                        <th class="ps-4 py-3" style="width: 160px;">Reference ID</th>
                        <th class="py-3">Timestamp Node</th>
                        <th class="py-3 text-end" style="width: 200px;">Financial Total</th>
                        <th class="pe-4 py-3 text-end" style="width: 180px;">Fulfillment State</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="fs-2 d-block mb-2">📋</span>
                                <p class="mb-0 fw-medium">No order data points or transaction receipts recorded yet.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in Model)
                        {
                            <tr>
                               
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-light border text-dark rounded px-2.5 py-1 fs-7 fw-bold font-monospace shadow-sm">
                                            #@order.Id.ToString().PadLeft(5, '0')
                                        </div>
                                    </div>
                                </td>

                              
                                <td>
                                    <div class="d-flex align-items-center gap-1.5 fs-7 text-secondary">
                                        <i class="bi bi-clock text-muted"></i>
                                        <span>Live Tracking Node</span>
                                    </div>
                                </td>

                              
                                <td class="text-end fw-bold text-dark price-cell">
                                    @string.Format("{0:C}", order.TotalAmount)
                                </td>

                               
                                <td class="pe-4 text-end">
                                    @{
                                        var statusStr = order.Status.ToString().ToLower() ?? "pending";
                                        var contextClass = statusStr switch
                                        {
                                            "completed" => "bg-success-subtle text-success border-success-subtle",
                                            "delivered" => "bg-success-subtle text-success border-success-subtle",
                                            "processing" => "bg-primary-subtle text-primary border-primary-subtle",
                                            "onway" => "bg-info-subtle text-info border-info-subtle",
                                            "cancelled" => "bg-danger-subtle text-danger border-danger-subtle",
                                            _ => "bg-warning-subtle text-warning-dark border-warning-subtle"
                                        };
                                    }
                                    <span class="badge rounded-pill border fw-medium px-2.5 py-1.5 x-small @contextClass">
                                        <i class="bi bi-circle-fill me-1" style="font-size: 0.45rem; vertical-align: middle;"></i>
                                        @order.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Platform Layout UI Helper Overrides */
    .fs-7 {
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }

    .x-small {
        font-size: 0.75rem;
    }

    .price-cell {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica;
    }

    .text-warning-dark {
        color: #664d03 !important;
    }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .bg-danger-subtle {
        background-color: #f8d7da !important;
    }

    .bg-primary-subtle {
        background-color: #cfe2ff !important;
    }

    .bg-info-subtle {
        background-color: #cff4fc !important;
    }

    .table-hover tbody tr:hover {
        background-color: #fafafa;
        transition: background-color 0.1s ease;
    }
</style>