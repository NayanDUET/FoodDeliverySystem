@{
}
@model IEnumerable<FoodDeliverySystem.Models.Entities.Order>

<h2>All Orders</h2>

<table class="table">

    @foreach (var order in Model)
    {
        <tr>
            <td>#@order.Id</td>
            <td>@order.TotalAmount</td>
            <td>@order.Status</td>
        </tr>
    }

</table>