@model IEnumerable<FoodDeliverySystem.Models.Entities.ApplicationUser>

<h2>Delivery Men</h2>

<table class="table">

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.FullName</td>
            <td>@item.Email</td>
        </tr>
    }

</table>