@{
}
@model IEnumerable<FoodDeliverySystem.Models.Entities.ApplicationUser>

<h2>Customers</h2>

<table class="table">

    @foreach (var user in Model)
    {
        <tr>
            <td>@user.FullName</td>
            <td>@user.Email</td>
        </tr>
    }

</table>