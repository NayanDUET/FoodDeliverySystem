@model IEnumerable<FoodDeliverySystem.Models.Entities.ApplicationUser>

<div class="container my-4" style="max-width: 950px;">

    <!-- Administrative Header Segment -->
    <div class="mb-4">
        <span class="text-uppercase tracking-wider text-muted fs-7 fw-bold">Platform Directories</span>
        <h2 class="fw-bold text-success mb-1">Registered Customers</h2>
        <p class="text-muted small">A comprehensive overview of your customer ecosystem accounts and status flags</p>
    </div>

    <!-- Main Data Directory Card Wrapper -->
    <div class="card shadow-lg border-0" style="border-radius: 1rem; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="table-light text-uppercase fs-7 text-muted">
                    <tr>
                        <th class="ps-4 py-3">Customer Identity</th>
                        <th class="py-3">Email Address</th>
                        <th class="pe-4 py-3 text-end" style="width: 140px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <span class="fs-2 d-block mb-2">👥</span>
                                <p class="mb-0 fw-medium">No registered customers found in the platform database.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <!-- Identity Column with Initial Avatar Circle -->
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-success-subtle text-success fw-bold d-flex align-items-center justify-content-center text-uppercase border border-success-subtle shadow-sm flex-shrink-0"
                                             style="width: 38px; height: 38px; font-size: 0.95rem;">
                                            @(!string.IsNullOrEmpty(user.FullName) ? user.FullName.Substring(0, 1) : "C")
                                        </div>
                                        <div>
                                            <span class="text-dark fw-bold d-block mb-0">
                                                @(string.IsNullOrEmpty(user.FullName) ? "Unnamed Customer" : user.FullName)
                                            </span>
                                            <span class="text-muted x-small d-block">UID: #@user.Id.ToString().Substring(0, Math.Min(8, user.Id.ToString().Length))</span>
                                        </div>
                                    </div>
                                </td>

                                <!-- Email Communications Channel -->
                                <td>
                                    <span class="text-secondary fw-medium fs-7">
                                        <i class="bi bi-envelope me-1.5 text-muted"></i>@user.Email
                                    </span>
                                </td>

                                <!-- Static Operational Status Pill Indicator -->
                                <td class="pe-4 text-end">
                                    <span class="badge rounded-pill bg-light text-success border border-success-subtle fw-medium px-2.5 py-1.5 x-small">
                                        <i class="bi bi-shield-check me-1"></i> Verified Account
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Framework Visual Parity Utility Helpers */
    .fs-7 {
        font-size: 0.8rem;
        letter-spacing: 0.5px;
    }

    .x-small {
        font-size: 0.75rem;
    }

    .bg-success-subtle {
        background-color: #e8f5e9 !important;
        color: #2e7d32 !important;
    }

    .table-hover tbody tr:hover {
        background-color: #fafafa;
        transition: background-color 0.1s ease;
    }
</style>