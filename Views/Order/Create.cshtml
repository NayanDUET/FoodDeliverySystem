@model FoodDeliverySystem.ViewModels.CreateOrderVM

<div class="d-flex justify-content-center align-items-center min-vh-75 my-4">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 500px; border-radius: 1rem;">

        <!-- Brand/Header Section -->
        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">Place Your Order</h2>
            <p class="text-muted small">Review your item and confirm your delivery details</p>
        </div>

        <form asp-action="Create" method="post">
            <input asp-for="FoodItemId" type="hidden" />

            <!-- Read-Only Food Item Display -->
            <div class="form-floating mb-3">
                <input class="form-control bg-light border-0 fw-semibold text-secondary"
                       value="@ViewBag.FoodName"
                       id="floatingFoodName"
                       readonly />
                <label for="floatingFoodName">Item to Order</label>
            </div>

            <!-- Quantity Field -->
            <div class="form-floating mb-3">
                <input asp-for="Quantity"
                       class="form-control"
                       id="floatingQuantity"
                       value="1"
                       min="1"
                       type="number"
                       placeholder="1" />
                <label asp-for="Quantity" for="floatingQuantity">Quantity</label>
                <span asp-validation-for="Quantity" class="text-danger small"></span>
            </div>

            <!-- Delivery Address Field (Textarea works beautifully with form-floating) -->
            <div class="form-floating mb-3">
                <textarea asp-for="DeliveryAddress"
                          class="form-control"
                          id="floatingAddress"
                          placeholder="Your Address"
                          style="height: 100px; resize: none;"></textarea>
                <label asp-for="DeliveryAddress" for="floatingAddress">Delivery Address</label>
                <span asp-validation-for="DeliveryAddress" class="text-danger small"></span>
            </div>

            <!-- Payment Method Dropdown -->
            <div class="form-floating mb-3">
                <select asp-for="PaymentMethod" id="paymentMethod" class="form-select">
                    <option value="" selected disabled hidden>Select Payment Method</option>
                    <option value="CashOnDelivery">Cash On Delivery</option>
                    <option value="Bkash">Bkash</option>
                    <option value="Rocket">Rocket</option>
                </select>
                <label asp-for="PaymentMethod" for="paymentMethod">Payment Method</label>
                <span asp-validation-for="PaymentMethod" class="text-danger small"></span>
            </div>

            <!-- Dynamic Mobile Number Field -->
            <div class="form-floating mb-4" id="mobileNumberDiv" style="display:none">
                <input asp-for="PaymentNumber" class="form-control" id="floatingMobile" placeholder="017xxxxxxxx" />
                <label asp-for="PaymentNumber" for="floatingMobile">Mobile Number</label>
                <span asp-validation-for="PaymentNumber" class="text-danger small"></span>
            </div>

            <!-- Action Button -->
            <button type="submit" class="btn btn-primary w-100 py-2.5 fw-semibold shadow-sm" style="border-radius: 0.5rem;">
                Confirm Order
            </button>
        </form>

    </div>
</div>

@section Scripts
{
    <script>
        document.getElementById("paymentMethod").addEventListener("change", function () {
            var div = document.getElementById("mobileNumberDiv");
            if (this.value === "Bkash" || this.value === "Rocket") {
                div.style.display = "block";
            } else {
                div.style.display = "none";
            }
        });
    </script>
}