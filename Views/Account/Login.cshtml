}
@model FoodDeliverySystem.ViewModels.LoginViewModel

<h2>Login</h2>

<form asp-action="Login">

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input asp-for="Password" class="form-control" />
    </div>

    <button class="btn btn-primary">
        Login
    </button>

</form>