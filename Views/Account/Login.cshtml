@model FoodDeliverySystem.ViewModels.LoginViewModel

<div class="d-flex justify-content-center align-items-center min-vh-75">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 400px; border-radius: 1rem;">

        <div class="text-center mb-4">
            <h2 class="fw-bold text-primary">Welcome Back</h2>
            <p class="text-muted small">Please sign in to your food delivery account</p>
        </div>

        <form asp-action="Login" autocomplete="off">
            <div class="form-floating mb-3">
                <input asp-for="Email" class="form-control" id="floatingEmail" placeholder="name@example.com" />
                <label asp-for="Email" for="floatingEmail">Email address</label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <input type="password" asp-for="Password" class="form-control" id="floatingPassword" placeholder="Password" />
                <label asp-for="Password" for="floatingPassword">Password</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button class="btn btn-primary w-100 py-2.5 fw-semibold shadow-sm" type="submit" style="border-radius: 0.5rem;">
                Sign In
            </button>
        </form>

    </div>
</div>