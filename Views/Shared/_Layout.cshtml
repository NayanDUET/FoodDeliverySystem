@using Microsoft.AspNetCore.Identity
@using FoodDeliverySystem.Models.Entities

@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FoodDeliverySystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FoodDeliverySystem.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">FoodDeliverySystem</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        

                        

                        @if (User.IsInRole("Customer") || !User.Identity!.IsAuthenticated)
                        {

                           

                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-controller="Home"
                                   asp-action="Index">
                                    Home
                                </a>
                            </li>

                            @* search bar *@

                            <form class="d-flex ms-3"
                                  asp-controller="Home"
                                  asp-action="Search"
                                  method="get">

                                <input class="form-control me-2"
                                       type="search"
                                       name="keyword"
                                       placeholder="Search food, restaurant or location"
                                       style="width:300px" />

                                <button class="btn btn-outline-success"
                                        type="submit">
                                    Search
                                </button>

                            </form>
                        }
                       

                        
                        @* Hide Menus Based on Role *@
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Admin"
                                   asp-action="Index">
                                    Admin Dashboard
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("RestaurantOwner"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Restaurant"
                                   asp-action="Index">
                                    My Restaurant
                                </a>
                            </li>
                        }
                        @if (User.IsInRole("Customer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Order"
                                   asp-action="MyOrders">
                                    My Orders
                                </a>
                            </li>
                        }


                        @if (User.IsInRole("DeliveryMan"))
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Delivery"
                                   asp-action="Index">
                                    Available Orders
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Delivery"
                                   asp-action="PickedOrders">
                                    My Picked Orders
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Delivery"
                                   asp-action="DeliveredOrders">
                                    Delivered Orders
                                </a>
                            </li>
                        }



                        </ul>



                    <ul class="navbar-nav ms-auto">

                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <span class="me-3">
                                 @(currentUser?.FullName)
                            </span>

                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post">

                                <button type="submit"
                                        class="btn btn-danger">
                                    Logout
                                </button>

                            </form>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-primary"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Login
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Sign Up
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - FoodDeliverySystem - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
