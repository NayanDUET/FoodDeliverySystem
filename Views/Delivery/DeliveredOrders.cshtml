@{
}
@model IEnumerable<FoodDeliverySystem.Models.Entities.Order>

<h2>Delivered Orders</h2>

<table class="table">
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>#@order.Id</td>
                <td>@order.DeliveryAddress</td>
                <td>@order.TotalAmount</td>
                <td>
                    <span class="badge bg-success">
                        Delivered
                    </span>
                </td>
            </tr>
        }
    </tbody>
</table>