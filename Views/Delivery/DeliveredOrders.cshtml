@model IEnumerable<FoodDeliverySystem.Models.Entities.Order>

<div class="container my-4" style="max-width: 950px;">

    <!-- Header Section -->
    <div class="mb-4">
        <span class="text-uppercase tracking-wider text-muted fs-7 fw-bold">Delivery Logs</span>
        <h2 class="fw-bold text-success mb-1">Delivered Orders</h2>
        <p class="text-muted small">A complete overview of your successfully completed drops</p>
    </div>

    <!-- Main History Card -->
    <div class="card shadow-lg border-0" style="border-radius: 1rem; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="table-light text-uppercase fs-7 text-muted">
                    <tr>
                        <th class="ps-4 py-3" style="width: 120px;">Order ID</th>
                        <th class="py-3">Delivery Address</th>
                        <th class="py-3" style="width: 140px;">Total Amount</th>
                        <th class="pe-4 py-3 text-end" style="width: 140px;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="fs-2 d-block mb-2">📦</span>
                                <p class="mb-0 fw-medium">No delivered orders found in your history.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in Model)
                        {
                            <tr>
                                <!-- Order ID -->
                                <td class="ps-4 fw-bold text-secondary">#@order.Id</td>

                                <!-- Delivery Address with auto-truncation wrapper to keep it clean -->
                                <td>
                                    <span class="text-dark fw-medium text-truncate d-block" style="max-width: 400px;" title="@order.DeliveryAddress">
                                        @order.DeliveryAddress
                                    </span>
                                </td>

                                <!-- Total Amount -->
                                <td class="fw-bold text-dark">
                                    $@order.TotalAmount
                                </td>

                                <!-- Premium Soft-Tint Badge -->
                                <td class="pe-4 text-end">
                                    <span class="badge rounded-pill px-3 py-2 text-success bg-success-subtle border border-success fw-semibold">
                                        <i class="bi bi-check-circle-fill me-1"></i> Delivered
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    /* Design consistency helpers */
    .fs-7 {
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
        color: #0f5132 !important;
    }

    .table-hover tbody tr:hover {
        background-color: #fafafa;
        transition: background-color 0.15s ease;
    }
</style>