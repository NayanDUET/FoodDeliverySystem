@{
}
@model IEnumerable<FoodDeliverySystem.Models.Entities.Order>

<h2>Available Orders</h2>

<table class="table">
    <thead>
        <tr>
            <th>Order</th>
            <th>Address</th>
            <th>Total</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>#@order.Id</td>
                <td>@order.DeliveryAddress</td>
                <td>@order.TotalAmount</td>

                <td>
                    <a asp-action="Pick"
                       asp-route-id="@order.Id"
                       class="btn btn-success">
                        Pick Order
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>