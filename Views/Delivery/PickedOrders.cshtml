@{
}
@model IEnumerable<FoodDeliverySystem.Models.Entities.Order>

<h2>My Picked Orders</h2>

<table class="table">
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>#@order.Id</td>
                <td>@order.DeliveryAddress</td>
                <td>@order.TotalAmount</td>

                <td>
                    <a asp-action="Delivered"
                       asp-route-id="@order.Id"
                       class="btn btn-primary">
                        Delivered
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>