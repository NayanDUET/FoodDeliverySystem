@model List<FoodDeliverySystem.Models.Entities.Restaurant>

<div class="container my-4">

    <!-- Header Block & Action Trigger -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <span class="text-uppercase tracking-wider text-muted fs-7 fw-bold">Merchant Hub</span>
            <h2 class="fw-bold text-dark mb-1">Registered Restaurants</h2>
            <p class="text-muted small mb-0">Monitor, scale operations, and handle localized menus across your culinary network</p>
        </div>
        <div>
            <a asp-action="Create" asp-route-restaurantId="@ViewBag.RestaurantId"
               class="btn btn-success rounded-pill px-4 py-2.5 fw-bold shadow-sm d-inline-flex align-items-center gap-2">
                <i class="bi bi-plus-circle-fill"></i> Create New Restaurant
            </a>
        </div>
    </div>

    <!-- Empty State Fallback -->
    @if (!Model.Any())
    {
        <div class="card border border-dashed p-5 text-center bg-white shadow-sm" style="border-radius: 1rem;">
            <span class="fs-1 d-block mb-2">🏪</span>
            <h4 class="fw-bold text-dark">No Restaurants Found</h4>
            <p class="text-muted small mb-3">You haven't onboarded any culinary partners to the portal network yet.</p>
            <a asp-action="Create" asp-route-restaurantId="@ViewBag.RestaurantId" class="btn btn-primary btn-sm rounded-pill px-3">
                Get Started
            </a>
        </div>
    }
    else
    {
        <!-- Modernized Grid System -->
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm bg-white overflow-hidden" style="border-radius: 1rem;">

                        <!-- Top Accent Banner Area -->
                        <div class="p-3.5 bg-light border-bottom d-flex align-items-start gap-3">
                            <div class="bg-primary text-white rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 45px; height: 45px;">
                                <i class="bi bi-shop fs-5"></i>
                            </div>
                            <div class="overflow-hidden">
                                <h5 class="fw-bold text-dark text-truncate mb-1" title="@item.Name">@item.Name</h5>
                                <span class="badge rounded-pill bg-primary-subtle text-primary border border-primary-subtle small-badge fw-medium">
                                    ID: #@item.Id
                                </span>
                            </div>
                        </div>

                        <!-- Core Directory Card Body -->
                        <div class="card-body p-3.5 d-flex flex-column justify-content-between">
                            <div class="mb-4 space-y-2">
                                <div class="d-flex align-items-start gap-2 text-muted fs-7">
                                    <i class="bi bi-geo-alt-fill text-danger flex-shrink-0 mt-0.5"></i>
                                    <span class="text-truncate-2" title="@item.Address">@item.Address</span>
                                </div>
                                <div class="d-flex align-items-center gap-2 text-muted fs-7">
                                    <i class="bi bi-telephone-fill text-success flex-shrink-0"></i>
                                    <span>@(string.IsNullOrEmpty(item.PhoneNumber) ? "No contact added" : item.PhoneNumber)</span>
                                </div>
                            </div>

                            <!-- Context Operations Dashboard Footer Split -->
                            <div class="pt-3 border-top">
                                <!-- Operational Panel Actions -->
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <a asp-controller="FoodItem" asp-action="Index" asp-route-restaurantId="@item.Id"
                                           class="btn btn-outline-primary btn-sm rounded-pill w-100 fw-bold py-2 d-flex align-items-center justify-content-center gap-1">
                                            <i class="bi bi-egg-fried"></i> Manage Food
                                        </a>
                                    </div>
                                    <div class="col-6">
                                        <a asp-controller="RestaurantOrders" asp-action="Index" asp-route-restaurantId="@item.Id"
                                           class="btn btn-outline-success btn-sm rounded-pill w-100 fw-bold py-2 d-flex align-items-center justify-content-center gap-1">
                                            <i class="bi bi-receipt"></i> View Orders
                                        </a>
                                    </div>
                                </div>

                                <!-- Administrative Modifier Actions -->
                                <div class="d-flex justify-content-end gap-2 fs-7 pt-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="text-warning text-decoration-none fw-semibold px-2 py-1 action-link">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <span class="text-black-50">|</span>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-decoration-none fw-semibold px-2 py-1 action-link">
                                        <i class="bi bi-trash3"></i> Delete
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* UI Helper Custom Overrides */
    .fs-7 {
        font-size: 0.875rem;
    }

    .p-3.5 {
        padding: 1rem !important;
    }

    .small-badge {
        font-size: 0.7rem;
        padding: 0.2rem 0.5rem;
    }

    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
    }

    /* Cross line multi-line clip mechanics */
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .space-y-2 > * + * {
        margin-top: 0.5rem !important;
    }

    /* Interactive micro transitions */
    .action-link {
        transition: opacity 0.15s ease;
    }

        .action-link:hover {
            opacity: 0.75;
            text-decoration: underline !important;
        }
</style>