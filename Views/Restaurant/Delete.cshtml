@model FoodDeliverySystem.Models.Entities.Restaurant

<div class="d-flex justify-content-center align-items-center min-vh-75 my-4">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 500px; border-radius: 1rem;">

        <!-- Header Warning Area -->
        <div class="text-center mb-4">
            <div class="bg-danger-subtle text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm-inset animate-pulse" style="width: 60px; height: 60px;">
                <i class="bi bi-exclamation-triangle fs-3"></i>
            </div>
            <h3 class="fw-bold text-dark mb-1">Remove Restaurant?</h3>
            <p class="text-muted small">Are you absolutely sure you want to delete this storefront? This action cannot be undone.</p>
        </div>

        <!-- Meta Entity Context Box -->
        <div class="bg-light rounded-3 p-3 border mb-4">
            <div class="mb-2 pb-2 border-bottom">
                <span class="text-uppercase tracking-wider text-muted fs-8 fw-bold">Restaurant Profile</span>
            </div>

            <div class="space-y-2">
                <div class="d-flex align-items-start gap-2 fs-7">
                    <span class="text-secondary fw-medium flex-shrink-0" style="width: 80px;">Name:</span>
                    <strong class="text-dark">@Model.Name</strong>
                </div>
                <div class="d-flex align-items-start gap-2 fs-7">
                    <span class="text-secondary fw-medium flex-shrink-0" style="width: 80px;">Address:</span>
                    <span class="text-dark">@Model.Address</span>
                </div>
                <div class="d-flex align-items-start gap-2 fs-7">
                    <span class="text-secondary fw-medium flex-shrink-0" style="width: 80px;">Phone:</span>
                    <span class="text-dark">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "No phone number listed" : Model.PhoneNumber)</span>
                </div>
            </div>
        </div>

        <!-- Form Submissions Trigger Footer Layout -->
        <form asp-action="Delete" method="post" class="m-0">
            <input type="hidden" asp-for="Id" />

            <div class="row g-2">
                <div class="col-6">
                    <a asp-action="Index" class="btn btn-light border w-100 py-2 rounded-pill fw-semibold text-secondary">
                        Cancel
                    </a>
                </div>
                <div class="col-6">
                    <button type="submit" class="btn btn-danger w-100 py-2 rounded-pill fw-bold shadow-sm">
                        <i class="bi bi-trash3-fill me-1"></i> Confirm Delete
                    </button>
                </div>
            </div>
        </form>

    </div>
</div>

<style>
    /* Styling elements for structure consistency */
    .fs-7 {
        font-size: 0.875rem;
    }

    .fs-8 {
        font-size: 0.72rem;
        letter-spacing: 0.5px;
    }

    .space-y-2 > * + * {
        margin-top: 0.5rem !important;
    }

    .bg-danger-subtle {
        background-color: #f8d7da !important;
        color: #842029 !important;
    }

    .shadow-sm-inset {
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.07);
    }

    /* Soft infinite alert pulsing helper */
    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.04);
        }

        100% {
            transform: scale(1);
        }
    }

    .animate-pulse {
        animation: pulse 2s infinite ease-in-out;
    }
</style>