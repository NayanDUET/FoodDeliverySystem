@model FoodDeliverySystem.Models.Entities.Restaurant

<div class="d-flex justify-content-center align-items-center min-vh-75 my-4">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 550px; border-radius: 1rem;">

        <!-- Brand/Header Section -->
        <div class="text-center mb-4">
            <h2 class="fw-bold text-success">Register Your Restaurant</h2>
            <p class="text-muted small">Enter your business information to launch your digital storefront</p>
        </div>

        <form asp-action="Create" method="post" autocomplete="off">

            <!-- Restaurant Name Field -->
            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" id="floatingRestName" placeholder="Restaurant Name" />
                <label asp-for="Name" for="floatingRestName">Restaurant Name</label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <!-- Description Field (Textarea works best for restaurant taglines/details) -->
            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" id="floatingDescription" placeholder="Description" style="height: 100px; resize: none;"></textarea>
                <label asp-for="Description" for="floatingDescription">Description / Cuisines</label>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- Address Field -->
            <div class="form-floating mb-3">
                <input asp-for="Address" class="form-control" id="floatingAddress" placeholder="123 Street Name" />
                <label asp-for="Address" for="floatingAddress">Street Address</label>
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>

            <!-- Phone Number Field -->
            <div class="form-floating mb-4">
                <input asp-for="PhoneNumber" type="tel" class="form-control" id="floatingPhone" placeholder="017xxxxxxxx" />
                <label asp-for="PhoneNumber" for="floatingPhone">Contact Phone Number</label>
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <!-- Action Button -->
            <button type="submit" class="btn btn-success w-100 py-2.5 fw-semibold shadow-sm" style="border-radius: 0.5rem;">
                Save & Open Shop
            </button>
        </form>

    </div>
</div>