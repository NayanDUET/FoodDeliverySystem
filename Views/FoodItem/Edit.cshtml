@model FoodDeliverySystem.Models.Entities.FoodItem

<div class="d-flex justify-content-center align-items-center min-vh-75 my-4">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 550px; border-radius: 1rem;">

        <!-- Header Section -->
        <div class="text-center mb-4">
            <h2 class="fw-bold text-success">Edit Food Item</h2>
            <p class="text-muted small">Update the details, pricing, or imagery for this dish</p>
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data" autocomplete="off">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RestaurantId" />

            <!-- Food Name Field -->
            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" id="floatingName" placeholder="Food Name" />
                <label asp-for="Name" for="floatingName">Food Name</label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <!-- Description Field -->
            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" id="floatingDescription" placeholder="Description" style="height: 100px; resize: none;"></textarea>
                <label asp-for="Description" for="floatingDescription">Description</label>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <!-- Price Field -->
            <div class="form-floating mb-3">
                <input asp-for="Price" type="number" step="0.01" class="form-control" id="floatingPrice" placeholder="0.00" />
                <label asp-for="Price" for="floatingPrice">Price ($)</label>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <!-- Image Management Grid Section -->
            <div class="mb-4">
                @if (Model.ImageUrl != null)
                {
                    <div class="row align-items-center g-3 mb-3 p-2 bg-light rounded-3 border">
                        <div class="col-auto">
                            <img src="@Model.ImageUrl" class="img-thumbnail rounded-3 shadow-sm" style="width: 80px; height: 80px; object-fit: cover;" alt="Current Food Image" />
                        </div>
                        <div class="col">
                            <span class="d-block small text-muted fw-bold text-uppercase">Current Image</span>
                            <span class="small text-secondary">This is what customers currently see.</span>
                        </div>
                    </div>
                }

                <div>
                    <label class="form-label text-muted small fw-semibold mb-1">@(Model.ImageUrl != null ? "Replace Image" : "Upload Image")</label>
                    <input type="file" name="imageFile" class="form-control custom-file-input" accept="image/*" />
                </div>
            </div>

            <!-- Action Button -->
            <button type="submit" class="btn btn-success w-100 py-2.5 fw-semibold shadow-sm" style="border-radius: 0.5rem;">
                Update Item
            </button>
        </form>

    </div>
</div>

<style>
    /* Continuous theme element styling for the upload tool */
    .custom-file-input::-webkit-file-upload-button {
        background-color: #198754;
        color: white;
        border: none;
        padding: 0.375rem 0.75rem;
        margin: -0.375rem -0.75rem;
        margin-inline-end: 0.75rem;
        border-radius: 0.375rem 0 0 0.375rem;
        transition: background-color 0.15s ease-in-out;
    }

    .custom-file-input:hover::-webkit-file-upload-button {
        background-color: #157347;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}