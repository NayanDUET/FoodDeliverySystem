@{
}
@model List<FoodDeliverySystem.Models.Entities.FoodItem>

<h2>Food Items - @ViewBag.RestaurantName</h2>

<a asp-action="Create"
   asp-route-restaurantId="@ViewBag.RestaurantId"
   class="btn btn-primary">
    Add Food Item
</a>

<a asp-controller="Restaurant"
   asp-action="Index"
   class="btn btn-secondary">
    Back to Restaurants
</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Available</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.IsAvailable</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>