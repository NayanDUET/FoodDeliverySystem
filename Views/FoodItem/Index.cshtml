@model List<FoodDeliverySystem.Models.Entities.FoodItem>

<div class="container my-4" style="max-width: 1000px;">

    <!-- Top Toolbar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Menu: @ViewBag.RestaurantName</h2>
            <p class="text-muted small mb-0">Manage your restaurant offerings and pricing</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Restaurant" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <a asp-action="Create" asp-route-restaurantId="@ViewBag.RestaurantId" class="btn btn-primary rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Food Item
            </a>
        </div>
    </div>

    <!-- Main Card -->
    <div class="card shadow-lg border-0" style="border-radius: 1rem; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase fs-7 text-muted">
                    <tr>
                        <th class="ps-4 py-3">Item</th>
                        <th class="py-3">Price</th>
                        <th class="py-3">Status</th>
                        <th class="py-3 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-menu-app fs-1 d-block mb-2 opacity-50"></i>
                                No items found. Start by adding your first dish!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        @if (item.ImageUrl != null)
                                        {
                                            <img src="@item.ImageUrl" class="rounded-3 shadow-sm me-3" style="width: 50px; height: 50px; object-fit: cover;" alt="@item.Name" />
                                        }
                                        else
                                        {
                                            <div class="bg-light rounded-3 me-3 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                                <i class="bi bi-image text-muted"></i>
                                            </div>
                                        }
                                        <div>
                                            <span class="d-block fw-bold text-dark">@item.Name</span>
                                            <small class="text-muted d-block text-truncate" style="max-width: 200px;">@item.Description</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="fw-bold text-primary">$@item.Price</td>
                                <td>
                                    @if (item.IsAvailable)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger rounded-pill px-3">Hidden</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-2">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .fs-7 {
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }

    .bg-success-subtle {
        background-color: #d1e7dd;
    }

    .bg-danger-subtle {
        background-color: #f8d7da;
    }
</style>