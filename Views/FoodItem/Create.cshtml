@model FoodDeliverySystem.Models.Entities.FoodItem

<div class="d-flex justify-content-center align-items-center min-vh-75 my-4">
    <div class="card shadow-lg border-0 p-4" style="width: 100%; max-width: 500px; border-radius: 1rem;">

      
        <div class="text-center mb-4">
            <h2 class="fw-bold text-success">Add Food Item</h2>
            <p class="text-muted small">Introduce a delicious new dish to your restaurant menu</p>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data" autocomplete="off">
            <input type="hidden" asp-for="RestaurantId" />

          
            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" id="floatingName" placeholder="e.g. Cheesy Pepperoni Pizza" />
                <label asp-for="Name" for="floatingName">Food Name</label>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

           
            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" id="floatingDescription" placeholder="Description" style="height: 100px; resize: none;"></textarea>
                <label asp-for="Description" for="floatingDescription">Description</label>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

           
            <div class="form-floating mb-3">
                <input asp-for="Price" type="number" step="0.01" class="form-control" id="floatingPrice" placeholder="0.00" />
                <label asp-for="Price" for="floatingPrice">Price ($)</label>
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            
            <div class="mb-4">
                <label class="form-label text-muted small fw-semibold mb-1">Food Image</label>
                <input type="file" name="imageFile" class="form-control custom-file-input" accept="image/*" />
            </div>

           
            <button type="submit" class="btn btn-success w-100 py-2.5 fw-semibold shadow-sm" style="border-radius: 0.5rem;">
                Save Item
            </button>
        </form>

    </div>
</div>

<style>
    /* Gives the file input button a polished, integrated look */
    .custom-file-input::-webkit-file-upload-button {
        background-color: #198754;
        color: white;
        border: none;
        padding: 0.375rem 0.75rem;
        margin: -0.375rem -0.75rem;
        margin-inline-end: 0.75rem;
        border-radius: 0.375rem 0 0 0.375rem;
        transition: background-color 0.15s ease-in-out;
    }

    .custom-file-input:hover::-webkit-file-upload-button {
        background-color: #157347;
    }
</style>