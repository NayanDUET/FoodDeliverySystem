@*    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860*@
@using FoodDeliverySystem.Models.Enums
@model FoodDeliverySystem.Models.Entities.Order

<div class="container my-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <span class="text-muted text-uppercase small tracking-wider">Order Management</span>
            <h2 class="fw-bold text-dark m-0">Order Details #@Model.Id</h2>
        </div>
        <div>
            <a asp-controller="RestaurantOrders"
               asp-action="Index"
               asp-route-restaurantId="@Model.RestaurantId"
               class="btn btn-sm btn-outline-secondary px-3 rounded-2">
                <i class="bi bi-arrow-left me-1"></i> Back to Orders
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Order Metadata Summary Card -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-white h-100">
                <h5 class="fw-bold text-dark mb-4 pb-2 border-bottom">Summary</h5>

                <!-- Status Row -->
                <div class="mb-4">
                    <label class="text-muted small text-uppercase fw-semibold d-block mb-2">Order Status</label>
                    @switch (Model.Status)
                    {
                        case OrderStatus.Pending:
                            <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2 rounded-pill fw-medium fs-7">Pending</span>
                            break;
                        case OrderStatus.OutForDelivery:
                            <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2 rounded-pill fw-medium fs-7">Out for Delivery</span>
                            break;
                        case OrderStatus.Delivered:
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill fw-medium fs-7">Delivered</span>
                            break;
                       
                        case OrderStatus.Cancelled:
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2 rounded-pill fw-medium fs-7">Rejected</span>
                            break;
                        default:
                            <span class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-pill fw-medium fs-7">@Model.Status</span>
                            break;
                    }
                </div>

                <!-- Delivery Address Row -->
                <div class="mb-4">
                    <label class="text-muted small text-uppercase fw-semibold d-block mb-1">Delivery Address</label>
                    <p class="text-dark fw-medium lh-base m-0">@Model.DeliveryAddress</p>
                </div>

                <!-- Timing / Metadata Row (Optional Placeholder if you have it in Model) -->
                <div class="mb-2">
                    <label class="text-muted small text-uppercase fw-semibold d-block mb-1">Created At</label>
                    <p class="text-secondary small m-0">@Model.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")</p>
                </div>
            </div>
        </div>

        <!-- Right Column: Food Items breakdown Table -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-3 overflow-hidden bg-white">
                <div class="card-header bg-light border-0 py-3 px-4">
                    <h5 class="fw-bold text-dark m-0">Items Ordered</h5>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light border-bottom">
                            <tr>
                                <th class="ps-4 py-3 text-uppercase text-muted fs-7 fw-semibold">Food Item</th>
                                <th class="py-3 text-uppercase text-muted fs-7 fw-semibold text-end">Price</th>
                                <th class="py-3 text-uppercase text-muted fs-7 fw-semibold text-center">Qty</th>
                                <th class="pe-4 py-3 text-uppercase text-muted fs-7 fw-semibold text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderItems)
                            {
                                var itemTotal = item.Price * item.Quantity;
                                <tr>
                                    <!-- Food Name -->
                                    <td class="ps-4 py-3">
                                        <span class="d-block text-dark fw-semibold">@item.FoodItem?.Name</span>
                                    </td>

                                    <!-- Price -->
                                    <td class="text-end text-secondary">
                                        @item.Price.ToString("C")
                                    </td>

                                    <!-- Quantity -->
                                    <td class="text-center">
                                        <span class="badge bg-light text-dark border px-2.5 py-1.5 rounded fw-medium">
                                            @item.Quantity
                                        </span>
                                    </td>

                                    <!-- Calculated Line Total -->
                                    <td class="pe-4 text-end fw-bold text-dark">
                                        @itemTotal.ToString("C")
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <!-- Table Footer for aggregate total -->
                        <tfoot class="table-light border-top">
                            <tr>
                                <td colspan="3" class="ps-4 py-3 text-end fw-bold text-secondary text-uppercase fs-7">Grand Total:</td>
                                <td class="pe-4 py-3 text-end fw-bold text-primary fs-5">
                                    @Model.TotalAmount.ToString("C")
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Supporting styling framework -->
<style>
    .fs-7 {
        font-size: 0.75rem;
    }

    .tracking-wider {
        letter-spacing: 0.05em;
    }
</style>