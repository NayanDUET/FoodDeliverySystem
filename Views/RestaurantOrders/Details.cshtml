@{
}

@model FoodDeliverySystem.Models.Entities.Order

<h2>Order #@Model.Id</h2>

<p>
    Address:
    @Model.DeliveryAddress
</p>

<p>
    Status:
    @Model.Status
</p>

<table class="table">

    <thead>
        <tr>
            <th>Food</th>
            <th>Price</th>
            <th>Qty</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model.OrderItems)
        {
            <tr>
                <td>@item.FoodItem?.Name</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
            </tr>
        }

    </tbody>
   

</table>

<a asp-controller="RestaurantOrders"
   asp-action="Index"
   asp-route-restaurantId="@Model.RestaurantId"
   class="btn btn-secondary">
    Back to Orders
</a>